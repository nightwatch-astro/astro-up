{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Astro-Up",
  "identifier": "dev.nightwatch.astro-up",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": "../../frontend"
    },
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "../../frontend"
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Astro-Up",
        "width": 1100,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": [
      "binaries/astro-up-cli"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExMEM2RDA1M0I2RTc0RkQKUldUOWRHNDdCVzBNRWFLZGUxTUZFL1NxdzIrVEJCamlQN1hKYUtQWDdEWndZWFo2dk0xSkt3bmQK",
      "endpoints": [
        "https://github.com/nightwatch-astro/astro-up/releases/latest/download/latest.json"
      ]
    }
  }
}
